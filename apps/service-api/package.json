{
  "name": "service-api",
  "version": "1.0.0",
  "description": "Medical Learning Portal API Service",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "dev:ssr": "nest start --watch",
    "prebuild": "pnpm --filter @medical-portal/shared build",
    "build": "rimraf dist && nest build",
    "build:ssr": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:smoke:admin": "tsx src/scripts/smoke-admin-endpoints.ts"
  },
  "dependencies": {
    "@medical-portal/shared": "workspace:*",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@supabase/supabase-js": "^2.39.0",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "ms": "^2.1.3",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.7",
    "rimraf": "^5.0.5",
    "tsx": "^4.6.2",
    "typescript": "^5.3.0"
  }
}
