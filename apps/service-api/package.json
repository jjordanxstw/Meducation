{
  "name": "service-api",
  "version": "1.0.0",
  "description": "Medical Learning Portal API Service",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "dev:ssr": "nest start --watch",
    "build": "nest build",
    "build:ssr": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "ts-node src/scripts/migrate.ts",
    "db:seed": "ts-node src/scripts/seed.ts"
  },
  "dependencies": {
    "@medical-portal/shared": "workspace:*",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^10",
    "@nestjs/passport": "^10",
    "@nestjs/platform-express": "^11.1.16",
    "@supabase/supabase-js": "^2.39.0",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.7",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.0"
  }
