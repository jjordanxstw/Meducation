# API Configuration
PORT=3000
NODE_ENV=development
APP_ENV=local

# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret for Admin Authentication (Required - generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Watermark secret (Optional - falls back to JWT_SECRET when omitted)
WATERMARK_SECRET=your-watermark-secret-key

# JWT Expiration (Optional - default: 1h)
JWT_EXPIRES_IN=1h

# Google OAuth (Required for Student Login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS Origins (Optional - comma separated, for production)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Admin auth cookie options (Optional)
# For cross-domain admin frontend, use: ADMIN_COOKIE_SAMESITE=none and ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=lax
ADMIN_COOKIE_SECURE=false
# Optional cookie domain for subdomain sharing (e.g. .example.com)
ADMIN_COOKIE_DOMAIN=

# Student auth cookie options (Optional)
# For cross-domain web-client, use: STUDENT_COOKIE_SAMESITE=none and STUDENT_COOKIE_SECURE=true
STUDENT_COOKIE_SAMESITE=lax
STUDENT_COOKIE_SECURE=false
# Optional cookie domain for subdomain sharing (e.g. .example.com)
STUDENT_COOKIE_DOMAIN=
