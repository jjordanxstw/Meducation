# Supabase Configuration
# Get these from Supabase Dashboard > Project Settings > API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Connection String (use IPv4 pooler for Windows)
# Get pooler URL from: Supabase Dashboard > Project Settings > Database > Connection String > IPv4
# Format: postgresql://postgres.[project-ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.project-ref:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
