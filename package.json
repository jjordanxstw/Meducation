{
  "name": "medical-learning-portal",
  "version": "1.0.0",
  "description": "Production-ready Medical Learning Portal Monorepo",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter web-client dev",
    "dev:admin": "pnpm --filter web-admin dev",
    "dev:api": "pnpm --filter service-api dev",
    "dev:ssr": "pnpm --filter service-api dev:ssr",
    "build": "pnpm run --parallel build",
    "build:web": "pnpm --filter web-client build",
    "build:admin": "pnpm --filter web-admin build",
    "build:api": "pnpm --filter @medical-portal/shared build && pnpm --filter service-api build",
    "build:ssr": "pnpm --filter web-client build:ssr && pnpm --filter service-api build:ssr",
    "verify:apps": "pnpm --filter @medical-portal/shared build && pnpm --filter service-api typecheck && pnpm --filter service-api lint && pnpm --filter service-api build && pnpm --filter web-admin build && pnpm --filter web-admin lint",
    "lint": "pnpm run --parallel lint",
    "test": "pnpm run --parallel test",
    "clean": "pnpm run --parallel clean && rimraf node_modules",
    "db": "tsx database/scripts/migrate.ts",
    "db:status": "tsx database/scripts/migrate.ts status",
    "db:migrate": "tsx database/scripts/migrate-apply.ts",
    "db:reset": "tsx database/scripts/reset.ts",
    "db:seed": "tsx database/scripts/seed.ts",
    "db:generate": "tsx database/scripts/generate-migration.ts",
    "admin:create": "tsx database/scripts/create-admin.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.13.5",
      "minimatch": "^9.0.7",
      "rollup": "^4.59.0",
      "lodash": "^4.17.23",
      "lodash-es": "^4.17.23",
      "qs": "^6.14.2",
      "file-type": "^21.3.1",
      "esbuild": "^0.25.0",
      "flatted": "^3.4.2",
      "ajv": "^8.18.0"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "bcrypt": "^6.0.0",
    "pg": "^8.20.0"
  }
}
